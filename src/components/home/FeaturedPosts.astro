---
import { getCollection } from 'astro:content';
import PostCard from '@components/blog/PostCard.astro';

const all  = await getCollection('posts', ({ data }) => !data.draft);
const posts = all
  .sort((a, b) => b.data.publishDate.getTime() - a.data.publishDate.getTime())
  .slice(0, 3);
---

<section class="section" aria-labelledby="featured-heading">
  <div class="container">

    <!-- Section header -->
    <div class="flex items-end justify-between mb-12" data-reveal-solo>
      <div>
        <p class="text-xs font-semibold text-neon-cyan uppercase tracking-widest mb-2">Latest writing</p>
        <h2 id="featured-heading" class="font-display font-bold text-3xl md:text-4xl text-text-primary">
          From the Blog
        </h2>
      </div>
      <a href="/blog"
         class="hidden sm:inline-flex items-center gap-2 text-sm font-medium text-text-secondary hover:text-neon-cyan transition-colors link-underline">
        All posts
        <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <path d="M5 12h14M12 5l7 7-7 7"/>
        </svg>
      </a>
    </div>

    <!-- Grid -->
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
      {posts.map((post, i) => <PostCard post={post} index={i} />)}
    </div>

    <!-- Mobile "All posts" link -->
    <div class="mt-8 text-center sm:hidden">
      <a href="/blog" class="text-sm text-neon-cyan link-underline">View all posts →</a>
    </div>

  </div>
</section>
