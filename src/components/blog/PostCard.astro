---
// PostCard.astro — static post card used on the home featured section
import Badge from '@components/ui/Badge';
import { formatDate } from '@utils/formatDate';
import { readingTime } from '@utils/readingTime';
import type { CollectionEntry } from 'astro:content';

interface Props {
  post: CollectionEntry<'posts'>;
  index?: number;
}

const { post, index = 0 } = Astro.props;
const { title, description, publishDate, tags } = post.data;
const mins = readingTime(post.body);

const GRADS = [
  'from-neon-cyan/20 to-neon-violet/20',
  'from-neon-violet/20 to-neon-magenta/20',
  'from-neon-magenta/20 to-neon-cyan/20',
];
const grad = GRADS[index % GRADS.length];
---

<article
  class="glass flex flex-col overflow-hidden group h-full"
  data-reveal
  data-reveal-group="posts"
>
  <!-- Colour strip -->
  <div class={`h-1.5 w-full bg-gradient-to-r ${grad}`}></div>

  <div class="p-6 flex flex-col flex-1">
    <!-- Tags -->
    <div class="flex flex-wrap gap-1.5 mb-4">
      {tags.slice(0, 3).map(t => <Badge client:load label={t} />)}
    </div>

    <!-- Title -->
    <h3 class="font-display font-semibold text-lg text-text-primary leading-snug mb-3 group-hover:text-neon-cyan transition-colors line-clamp-2">
      <a href={`/blog/${post.slug}`} class="focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-neon-cyan rounded">
        {title}
      </a>
    </h3>

    <!-- Excerpt -->
    <p class="text-sm text-text-secondary leading-relaxed line-clamp-3 flex-1">
      {description}
    </p>

    <!-- Footer -->
    <div class="flex items-center justify-between mt-5 pt-4 border-t border-white/[0.07] text-xs text-text-muted">
      <time datetime={publishDate.toISOString().split('T')[0]}>
        {formatDate(publishDate)}
      </time>
      <span>{mins} min read</span>
    </div>
  </div>
</article>
