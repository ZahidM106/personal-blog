---
import PageLayout from '@layouts/PageLayout.astro';
import Hero from '@components/home/Hero';
import FeaturedPosts from '@components/home/FeaturedPosts.astro';
---

<PageLayout
  title="Zahid Mehmood — Accounting & Finance"
  description="UAE & UK tax compliance, bookkeeping software, and management accounting — written from two years of real client work."
>
  <!-- Hero: React island with particle canvas + scramble animation -->
  <Hero client:load />

  <!-- Intro blurb -->
  <section class="section bg-surface" aria-labelledby="intro-heading">
    <div class="container max-w-3xl text-center">
      <p class="text-xs font-semibold text-neon-violet uppercase tracking-widest mb-4" data-reveal-solo>
        Why this blog
      </p>
      <h2 id="intro-heading" class="font-display font-bold text-3xl md:text-4xl text-text-primary mb-6 text-balance" data-reveal-solo>
        Practical accounting knowledge,<br/>
        <span class="gradient-text">not textbook theory</span>
      </h2>
      <p class="text-text-secondary text-lg leading-relaxed" data-reveal-solo>
        I work simultaneously at two firms — managing UAE client tax returns at 1Financial-FZCO and preparing
        UK Self Assessment and VAT returns at HA & Co. Chartered Certified Accountants.
        Everything I write here comes from that daily practice, not from studying in isolation.
      </p>
    </div>
  </section>

  <!-- Featured posts -->
  <FeaturedPosts />

  <!-- Quick links / contact strip -->
  <section class="section bg-surface" aria-labelledby="connect-heading">
    <div class="container max-w-3xl text-center">
      <h2 id="connect-heading" class="font-display font-bold text-2xl text-text-primary mb-4" data-reveal-solo>
        Get in touch
      </h2>
      <p class="text-text-secondary mb-8" data-reveal-solo>
        Have a question about UAE or UK tax? Want to collaborate? I'm always happy to hear from fellow accountants.
      </p>
      <div class="flex flex-col sm:flex-row items-center justify-center gap-4" data-reveal-solo>
        <a href="mailto:itszahid106@gmail.com"
           class="inline-flex items-center gap-2 px-6 py-3 rounded-xl bg-gradient-neon text-white text-sm font-semibold shadow-glow-cyan hover:shadow-[0_0_40px_rgba(0,229,255,0.35)] transition-shadow">
          ✉ Email me
        </a>
        <a href="/about"
           class="inline-flex items-center gap-2 px-6 py-3 rounded-xl border border-white/15 text-text-secondary hover:border-neon-cyan/40 hover:text-neon-cyan transition-colors text-sm font-medium">
          Read my full bio →
        </a>
      </div>
    </div>
  </section>

</PageLayout>
