---
import { getCollection } from 'astro:content';
import PostLayout from '@layouts/PostLayout.astro';

export async function getStaticPaths() {
  const posts  = await getCollection('posts', ({ data }) => !data.draft);
  // Sort once outside the map so we never mutate the array mid-iteration
  const sorted = [...posts].sort((a, b) => b.data.publishDate.getTime() - a.data.publishDate.getTime());

  return sorted.map((post, idx) => ({
    params: { slug: post.slug },
    props: {
      post,
      prev: idx < sorted.length - 1 ? sorted[idx + 1] : null,
      next: idx > 0                  ? sorted[idx - 1] : null,
    },
  }));
}

const { post, prev, next } = Astro.props;
const { Content, headings } = await post.render();
---

<PostLayout {post} {prev} {next} {headings}>
  <Content />
</PostLayout>
