---
import PageLayout from '@layouts/PageLayout.astro';
import PostGrid from '@components/blog/PostGrid';
import { getCollection } from 'astro:content';
import { readingTime } from '@utils/readingTime';

const all = await getCollection('posts', ({ data }) => !data.draft);
const posts = all
  .sort((a, b) => b.data.publishDate.getTime() - a.data.publishDate.getTime())
  .map(p => ({
    slug:        p.slug,
    title:       p.data.title,
    description: p.data.description,
    publishDate: p.data.publishDate.toISOString(),
    tags:        p.data.tags,
    readingTime: readingTime(p.body),
    featured:    p.data.featured,
  }));
---

<PageLayout
  title="Blog — Zahid Mehmood"
  description="Practical articles on UAE & UK taxation, bookkeeping software, and management accounting."
>
  <!-- Page header -->
  <div class="pt-36 pb-16 px-6 bg-surface border-b border-white/[0.06]">
    <div class="container max-w-3xl">
      <p class="text-xs font-semibold text-neon-cyan uppercase tracking-widest mb-3">Writing</p>
      <h1 class="font-display font-bold text-5xl md:text-6xl text-text-primary mb-4">Blog</h1>
      <p class="text-text-secondary text-lg max-w-xl leading-relaxed">
        {posts.length} articles on UAE &amp; UK tax, bookkeeping software, and management accounting.
        All written from real practice.
      </p>
    </div>
  </div>

  <!-- Interactive grid: React island -->
  <section class="section">
    <div class="container">
      <PostGrid posts={posts} client:load />
    </div>
  </section>

</PageLayout>
