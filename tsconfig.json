{
  "extends": "astro/tsconfigs/strict",
  "compilerOptions": {
    "baseUrl": ".",
    "paths": {
      "@/*":            ["./src/*"],
      "@components/*": ["./src/components/*"],
      "@layouts/*":    ["./src/layouts/*"],
      "@utils/*":      ["./src/utils/*"],
      "@styles/*":     ["./src/styles/*"],
      "@data/*":       ["./src/data/*"]
    },
    "jsx": "react-jsx",
    "jsxImportSource": "react"
  }
}
